{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/process-email-reports",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/process-drips",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/retry-webhooks",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/daily-digest",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/cron/poll-lsa-leads",
      "schedule": "*/5 * * * *"
    }
  ]
}
